# =========================
# FlashMall 本地 Docker 环境变量示例
# 用法：cp .env.example .env
# 然后按需覆盖端口/密码。
# =========================

# 容器时区（日志时间对齐）
TZ=UTC

# -------------------------
# MySQL
# -------------------------
# 宿主机映射端口（Spring Boot dev/perf 默认连 localhost:3306）
MYSQL_PORT=3306
# root 密码（需与 application-dev/perf.yml 一致，当前默认 123456）
MYSQL_ROOT_PASSWORD=123456

# -------------------------
# Redis
# -------------------------
# 宿主机映射端口（Spring Boot 默认连 localhost:6379）
REDIS_PORT=6379

# -------------------------
# RabbitMQ
# -------------------------
# AMQP 端口（应用连接端口）
RABBITMQ_AMQP_PORT=5672
# 管理台端口（浏览器访问 http://localhost:15672）
RABBITMQ_MANAGEMENT_PORT=15672
# 默认账号密码（与 application-dev/perf.yml 的 guest/guest 对齐）
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
