<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.OrderMapper">

    <!-- 插入订单。useGeneratedKeys 会把自增ID回填到 Order.id -->
    <insert id="insert" parameterType="Order" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders (user_id, total_price, status, created_at)
        VALUES (#{userId}, #{totalPrice}, #{status}, #{createdAt})
    </insert>

    <!-- 根据 ID 查询订单主表 -->
    <select id="findById" parameterType="long" resultType="Order">
        SELECT id, user_id, total_price, status, created_at
        FROM orders
        WHERE id = #{id}
    </select>

    <select id="countAllOrders" resultType="long">
        SELECT COUNT(*)
        FROM orders
    </select>

    <select id="countDistinctUsersByProduct" resultType="long">
        SELECT COUNT(DISTINCT o.user_id)
        FROM orders o
                 JOIN order_item oi ON o.id = oi.order_id
        WHERE oi.product_id = #{productId}
    </select>

    <select id="latestOrderCreatedAt" resultType="java.time.LocalDateTime">
        SELECT MAX(created_at)
        FROM orders
    </select>

</mapper>
